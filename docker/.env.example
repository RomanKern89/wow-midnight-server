# Copy to .env and edit.  NEVER commit your real .env (it's git-ignored).

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me-root
DB_USER=trinity
DB_PASS=change-me
MYSQL_PORT=3306

# --- Realm / login addresses the CLIENT must reach ---
# Public IP (or LAN IP) of the host running these containers.
REALM_ADDRESS=127.0.0.1
LOGIN_REST_EXTERNAL_ADDRESS=127.0.0.1

# --- Build (optional) ---
# TC_BRANCH=master
# BUILD_JOBS=8
